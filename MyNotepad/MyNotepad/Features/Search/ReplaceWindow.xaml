<core:AnimatedWindow x:Class="MyNotepad.Features.Search.ReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:MyNotepad.Core"
        Title="Replace" Height="210" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        ShowInTaskbar="False">

    <Border x:Name="ContentPanel" Margin="16">
        <Border.RenderTransform>
            <TranslateTransform x:Name="ContentTranslate" Y="-15"/>
        </Border.RenderTransform>

        <StackPanel>
            <TextBlock Text="Search for:" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtFind"
                     Background="#2D2D2D" Foreground="#D4D4D4"
                     BorderBrush="#454545" BorderThickness="1"
                     Padding="8,5" FontSize="13" CaretBrush="White"/>

            <TextBlock Text="Replace with:" Foreground="#AAAAAA" FontSize="11" Margin="0,10,0,5"/>
            <TextBox x:Name="TxtReplace"
                     Background="#2D2D2D" Foreground="#D4D4D4"
                     BorderBrush="#454545" BorderThickness="1"
                     Padding="8,5" FontSize="13" CaretBrush="White"/>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Right">
                <CheckBox x:Name="ChkMatchCase" Content="Match case"
                          Foreground="#D4D4D4" FontSize="12"
                          VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="Replace" Click="Replace_Click"
                        Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,6,0"/>
                <Button Content="Replace All" Click="ReplaceAll_Click"
                        Style="{StaticResource ToolbarButtonStyle}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</core:AnimatedWindow>





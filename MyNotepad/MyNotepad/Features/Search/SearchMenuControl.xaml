<MenuItem x:Class="MyNotepad.Features.Search.SearchMenuControl"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          Header="Search"
          Style="{StaticResource TopLevelMenuItemStyle}">
    <MenuItem Header="Find..."       Command="{Binding OpenFindCommand}"       Style="{StaticResource SubMenuItemStyle}"/>
    <MenuItem Header="Replace..."    Command="{Binding OpenReplaceCommand}"    Style="{StaticResource SubMenuItemStyle}"/>
</MenuItem>


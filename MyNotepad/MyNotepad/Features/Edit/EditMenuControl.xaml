<MenuItem x:Class="MyNotepad.Features.Edit.EditMenuControl"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          Header="Edit"
          FocusManager.IsFocusScope="False"
          Style="{StaticResource TopLevelMenuItemStyle}">
    <MenuItem Header="Undo"  Command="ApplicationCommands.Undo"  Style="{StaticResource SubMenuItemStyle}"/>
    <MenuItem Header="Redo"  Command="ApplicationCommands.Redo"  Style="{StaticResource SubMenuItemStyle}"/>
    <MenuItem Header="Cut"   Command="ApplicationCommands.Cut"   Style="{StaticResource SubMenuItemStyle}"/>
    <MenuItem Header="Copy"  Command="ApplicationCommands.Copy"  Style="{StaticResource SubMenuItemStyle}"/>
    <MenuItem Header="Paste" Command="ApplicationCommands.Paste" Style="{StaticResource SubMenuItemStyle}"/>
</MenuItem>

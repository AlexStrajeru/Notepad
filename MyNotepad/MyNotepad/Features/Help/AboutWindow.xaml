<Window x:Class="MyNotepad.Features.Help.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Height="300" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    <StackPanel Margin="30" VerticalAlignment="Center" >
        <TextBlock Text="MyNotepad" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>
        <TextBlock Text="Nume: Strajeru Alexandru" FontSize="14" Foreground="#D4D4D4" Margin="0,4"/>
        <TextBlock Text="Grupa: 10LF244" FontSize="14" Foreground="#D4D4D4" Margin="0,4"/>
        <TextBlock FontSize="14" Foreground="#D4D4D4" Margin="0,4">
            <Hyperlink NavigateUri="mailto:strajeru.alexandru@student.usv.ro"
                       RequestNavigate="Hyperlink_RequestNavigate"
                       Foreground="CornflowerBlue">
                alexandru.strajeru@student.unitbv.ro
            </Hyperlink>
        </TextBlock>
        <Button Content="OK" Width="80" Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Click="OK_Click"
                Background="#3C3C3C"
                Foreground="White"
                BorderThickness="0"
                Padding="10,5">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#505050"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </StackPanel>
</Window>


<MenuItem x:Class="MyNotepad.Features.View.ViewMenuControl"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          Header="View"
          Style="{StaticResource TopLevelMenuItemStyle}">
    <MenuItem Header="Standard"        Command="{Binding HideFolderExplorerCommand}" Style="{StaticResource SubMenuItemStyle}"/>
    <MenuItem Header="Folder Explorer" Command="{Binding ShowFolderExplorerCommand}" Style="{StaticResource SubMenuItemStyle}"/>
</MenuItem>

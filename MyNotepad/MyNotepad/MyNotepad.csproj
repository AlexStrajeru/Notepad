<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net10.0-windows</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <UseWPF>true</UseWPF>
        <ApplicationIcon>Fonts\Logo.ico</ApplicationIcon>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="AvalonEdit" Version="6.3.1.120" />
    </ItemGroup>

    <ItemGroup>
      <Resource Include="icons for notepad\*.png"/>
      <Resource Include="Fonts\*.ttf"/>
      <Resource Include="Fonts\Logo.ico"/>
      <Resource Include="Fonts\Logo.jpg"/>
      <Resource Include="Fonts\notepad-seeklogo.png"/>
    </ItemGroup>

</Project>

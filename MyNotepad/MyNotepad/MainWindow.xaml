<Window x:Class="MyNotepad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyNotepad"
        mc:Ignorable="d"
        Title="MyNotepad" Height="600" Width="1000">
    <DockPanel LastChildFill="True" Background="#1E1E1E">
        <Menu DockPanel.Dock="Top"
              Background="#3C3C3C" 
              Foreground="#CCCCCC"
              Padding="4">
            
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Background" Value="#3C3C3C"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                </Style>
            </Menu.Resources>
            
            <MenuItem Header="File"> 
                <MenuItem Header="New" Click="New_Click"/>
                <MenuItem Header="Open" Click="Open_Click"/>
                <MenuItem Header="Save" Click="Save_Click"/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </MenuItem>
            
            <MenuItem Header="Edit">
                <MenuItem Header="Undo" Click="Undo_Click"/>
                <MenuItem Header="Redo" Click="Redo_Click"/>
                <Separator/>
                <MenuItem Header="Cut" Click="Cut_Click"/>
                <MenuItem Header="Copy" Click="Copy_Click"/>
                <MenuItem Header="Paste" Click="Paste_Click"/>
                <Separator/>
                <MenuItem Header="Select All" Click="SelectAll_Click"/>
            </MenuItem>
        </Menu>
        
        <TextBox x:Name="textBox"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="14"
                 Background="#1E1E1E"
                 Foreground="#D4D4D4"
                 CaretBrush="White"
                 BorderThickness="0"
                 Padding="10"/>
    </DockPanel>
</Window>

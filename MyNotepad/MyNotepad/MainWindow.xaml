<Window x:Class="MyNotepad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:MyNotepad.Core"
        xmlns:file="clr-namespace:MyNotepad.Features.File"
        xmlns:edit="clr-namespace:MyNotepad.Features.Edit"
        xmlns:status="clr-namespace:MyNotepad.Features.StatusBar"
        xmlns:help="clr-namespace:MyNotepad.Features.Help"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="MyNotepad" Height="600" Width="1000">

    <Window.DataContext>
        <core:AppViewModel/>
    </Window.DataContext>

    <DockPanel LastChildFill="True" Background="#1E1E1E">

        <Menu DockPanel.Dock="Top" Background="#3C3C3C" Padding="5">
            <file:FileMenuControl/>
            <edit:EditMenuControl/>
            <help:HelpMenuControl/>
        </Menu>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#2D2D2D">
            <Button Content="📄 New"   Command="{Binding NewCommand}"      Style="{StaticResource ToolbarButtonStyle}" ToolTip="New file"/>
            <Button Content="📂 Open"  Command="{Binding OpenCommand}"     Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open file"/>
            <Button Content="💾 Save"  Command="{Binding SaveCommand}"     Style="{StaticResource ToolbarButtonStyle}" ToolTip="Save file"/>
            <Separator Width="1" Background="#454545" Margin="4,2"/>
            <Button Content="↩ Undo"  Click="UndoButton_Click"  Style="{StaticResource ToolbarButtonStyle}" ToolTip="Undo"/>
            <Button Content="↪ Redo"  Click="RedoButton_Click"  Style="{StaticResource ToolbarButtonStyle}" ToolTip="Redo"/>
            <Separator Width="1" Background="#454545" Margin="4,2"/>
            <Button Content="✂ Cut"   Click="CutButton_Click"   Style="{StaticResource ToolbarButtonStyle}" ToolTip="Cut"/>
            <Button Content="📋 Copy" Click="CopyButton_Click"  Style="{StaticResource ToolbarButtonStyle}" ToolTip="Copy"/>
            <Button Content="📌 Paste" Click="PasteButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Paste"/>
            <Separator Width="1" Background="#454545" Margin="4,2"/>
            <Button Content="✖ Close all" Command="{Binding CloseAllCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Close all files"/>
        </StackPanel>

        <status:StatusBarControl DockPanel.Dock="Bottom" DataContext="{Binding StatusBar}"/>

        <TabControl x:Name="MainTabControl" ItemsSource="{Binding OpenTabs}" SelectedItem="{Binding ActiveTab}">
            <TabControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </TabControl.ItemsPanel>

            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayTitle}" VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0"/>
                        <Button Content="×"
                                Style="{StaticResource TabCloseButtonStyle}"
                                Command="{Binding DataContext.CloseCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <avalon:TextEditor x:Name="Editor"
                             ShowLineNumbers="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="14"
                             Background="#1E1E1E"
                             Foreground="#D4D4D4"
                             BorderThickness="0"
                             Padding="5"
                             Loaded="Editor_Loaded"/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

    </DockPanel>
</Window>


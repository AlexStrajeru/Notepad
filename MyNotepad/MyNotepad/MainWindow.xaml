<Window x:Class="MyNotepad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:MyNotepad.Core"
        xmlns:file="clr-namespace:MyNotepad.Features.File"
        xmlns:edit="clr-namespace:MyNotepad.Features.Edit"
        xmlns:status="clr-namespace:MyNotepad.Features.StatusBar"
        xmlns:help="clr-namespace:MyNotepad.Features.Help"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="MyNotepad" Height="600" Width="1000"
        SnapsToDevicePixels="True" UseLayoutRounding="True">

    <Window.DataContext>
        <core:AppViewModel/>
    </Window.DataContext>

    <DockPanel LastChildFill="True" Background="#1E1E1E">

        <Menu DockPanel.Dock="Top" Background="#3C3C3C" Padding="5">
            <file:FileMenuControl/>
            <edit:EditMenuControl/>
            <help:HelpMenuControl/>
        </Menu>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#2D2D2D" RenderOptions.BitmapScalingMode="HighQuality">
            <Button Command="{Binding NewCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="New file">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/file-plus.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Button Command="{Binding OpenCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open file">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/folder-open.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Button Command="{Binding SaveCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Save file">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/floppy-disk.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Separator Width="1" Background="#454545" Margin="4,2"/>
            <Button Click="UndoButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Undo">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/arrow-counter-clockwise.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Button Click="RedoButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Redo">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/arrow-clockwise.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Separator Width="1" Background="#454545" Margin="4,2"/>
            <Button Click="CutButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Cut">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/scissors.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Button Click="CopyButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Copy">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/copy.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Button Click="PasteButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Paste">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/clipboard-text.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Separator Width="1" Background="#454545" Margin="4,2"/>
            <Button Command="{Binding CloseAllCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Close all files">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/x-square.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
        </StackPanel>

        <status:StatusBarControl DockPanel.Dock="Bottom" DataContext="{Binding StatusBar}"/>

        <TabControl x:Name="MainTabControl" ItemsSource="{Binding OpenTabs}" SelectedItem="{Binding ActiveTab}">
            <TabControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </TabControl.ItemsPanel>

            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayTitle}" VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0"/>
                        <Button Content="×"
                                Style="{StaticResource TabCloseButtonStyle}"
                                Command="{Binding DataContext.CloseCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <avalon:TextEditor x:Name="Editor"
                             ShowLineNumbers="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="{StaticResource JetBrainsMono}"
                             FontSize="14"
                             Background="#1E1E1E"
                             Foreground="#D4D4D4"
                             BorderThickness="0"
                             Padding="5"
                             Loaded="Editor_Loaded"/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

    </DockPanel>
</Window>


<Window x:Class="MyNotepad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MyNotepad.ViewModels"
        Title="MyNotepad" Height="600" Width="1000">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel LastChildFill="True" Background="#1E1E1E" >
        
        <Menu DockPanel.Dock="Top" Background="#3C3C3C" Padding="5">
            
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#D4D4D4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" Padding="10,4" CornerRadius="6" Margin="3">
                                    <Grid>
                                        <ContentPresenter ContentSource="Header" />
                        
                                        <Popup x:Name="Pop" IsOpen="{TemplateBinding IsSubmenuOpen}" Placement="Bottom" AllowsTransparency="True">
                                            <Border Background="#2D2D2D" BorderBrush="#454545" BorderThickness="1" Padding="2" CornerRadius="10" Margin="0,4,0,0">
                                                <StackPanel IsItemsHost="True" />
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </Border>
                
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="DimGray"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                    
                                    <Trigger Property="IsSubmenuOpen" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="DimGray"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                    
                                    <Trigger Property="Role" Value="SubmenuItem">
                                        <Setter TargetName="Pop" Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Menu.Resources>
            
            <MenuItem Header="File" Background="Transparent" FontSize="13">
                <MenuItem Header="New"  Command="{Binding NewCommand}"  Background="Transparent"/>
                <MenuItem Header="Open" Command="{Binding OpenCommand}" Background="Transparent"/>
                <MenuItem Header="Save" Command="{Binding SaveCommand}" Background="Transparent"/>
                <MenuItem Header="Exit" Command="{Binding ExitCommand}" Background="Transparent"/>
            </MenuItem>

            <MenuItem Header="Edit" Background="Transparent" FontSize="13">
                <MenuItem Header="Undo"       Command="ApplicationCommands.Undo"      Background="Transparent"/>
                <MenuItem Header="Redo"       Command="ApplicationCommands.Redo"      Background="Transparent"/>
                <MenuItem Header="Cut"        Command="ApplicationCommands.Cut"       Background="Transparent"/>
                <MenuItem Header="Copy"       Command="ApplicationCommands.Copy"      Background="Transparent"/>
                <MenuItem Header="Paste"      Command="ApplicationCommands.Paste"     Background="Transparent"/>
                <MenuItem Header="Select All" Command="ApplicationCommands.SelectAll" Background="Transparent"/>
            </MenuItem>
        </Menu>
        
        <TextBox x:Name="textBox"
                 Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="14"
                 Background="#1E1E1E"
                 Foreground="#D4D4D4"
                 CaretBrush="White"
                 BorderThickness="0"
                 Padding="10"/>
    </DockPanel>
</Window>
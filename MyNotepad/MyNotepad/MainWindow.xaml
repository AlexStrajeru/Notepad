<core:AnimatedWindow x:Class="MyNotepad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:MyNotepad.Core"
        xmlns:file="clr-namespace:MyNotepad.Features.File"
        xmlns:edit="clr-namespace:MyNotepad.Features.Edit"
        xmlns:search="clr-namespace:MyNotepad.Features.Search"
        xmlns:view="clr-namespace:MyNotepad.Features.View"
        xmlns:status="clr-namespace:MyNotepad.Features.StatusBar"
        xmlns:help="clr-namespace:MyNotepad.Features.Help"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="MyNotepad" Height="600" Width="1000"
        Icon="Fonts/notepad-seeklogo.png"
        SnapsToDevicePixels="True" UseLayoutRounding="True">

    <Window.DataContext>
        <core:AppViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel LastChildFill="True" Background="#1E1E1E">

        <Menu DockPanel.Dock="Top" Background="#3C3C3C" Padding="5">
            <file:FileMenuControl/>
            <edit:EditMenuControl/>
            <search:SearchMenuControl/>
            <view:ViewMenuControl/>
            <help:HelpMenuControl/>
        </Menu>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#2D2D2D" RenderOptions.BitmapScalingMode="HighQuality">
            <Button Command="{Binding NewCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="New file">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/file-plus.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Button Command="{Binding OpenCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open file">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/folder-open.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Button Command="{Binding SaveCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Save file">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/floppy-disk.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Button Command="{Binding SaveAsCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Save As...">
                <StackPanel Orientation="Horizontal">
                    <Rectangle Width="18" Height="18">
                        <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                        <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/floppy-disk.png"/></Rectangle.OpacityMask>
                    </Rectangle>
                    <TextBlock Text="+" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Bottom" Margin="1,0,0,0"/>
                </StackPanel>
            </Button>
            <Rectangle Width="1" Height="20" Fill="#454545" Margin="4,0" VerticalAlignment="Center"/>
            <Button Click="UndoButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Undo">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/arrow-counter-clockwise.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Button Click="RedoButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Redo">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/arrow-clockwise.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Rectangle Width="1" Height="20" Fill="#454545" Margin="4,0" VerticalAlignment="Center"/>
            <Button Click="CutButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Cut">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/scissors.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Button Click="CopyButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Copy">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/copy.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Button Click="PasteButton_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Paste">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/clipboard-text.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
            <Rectangle Width="1" Height="20" Fill="#454545" Margin="4,0" VerticalAlignment="Center"/>
            <Button Command="{Binding CloseAllCommand}" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Close all files">
                <Rectangle Width="18" Height="18">
                    <Rectangle.Fill><SolidColorBrush Color="White"/></Rectangle.Fill>
                    <Rectangle.OpacityMask><ImageBrush ImageSource="icons for notepad/x-square.png"/></Rectangle.OpacityMask>
                </Rectangle>
            </Button>
        </StackPanel>

        <status:StatusBarControl DockPanel.Dock="Bottom" DataContext="{Binding StatusBar}"/>

        <!-- Folder Explorer panel (stanga) cu animatie slide -->
        <Border x:Name="FolderExplorerPanel" DockPanel.Dock="Left" Width="0" Background="#252526"
                BorderBrush="#3C3C3C" BorderThickness="0,0,1,0" ClipToBounds="True">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFolderExplorerVisible}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="250" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel Width="250">
                <TextBlock DockPanel.Dock="Top" Text="Folder Explorer" Foreground="#AAAAAA" FontSize="12" Margin="10,8"/>
                <TreeView x:Name="FolderTreeView" Background="#252526" BorderThickness="0" Foreground="#D4D4D4"
                          Padding="4" ItemsSource="{Binding Explorer.Items}" MouseDoubleClick="FolderTreeView_MouseDoubleClick">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="0,2" ContextMenuOpening="StackPanel_ContextMenuOpening">
                                <StackPanel.ContextMenu>
                                    <ContextMenu Opened="FolderContextMenu_Opened">
                                        <MenuItem Header="New file" Click="FolderContextMenu_NewFile"/>
                                        <MenuItem Header="Copy path" Click="FolderContextMenu_CopyPath"/>
                                        <MenuItem Header="Copy folder" Click="FolderContextMenu_CopyFolder"/>
                                        <MenuItem Header="Paste folder" Click="FolderContextMenu_PasteFolder"/>
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <TextBlock Text="{Binding Icon}" Foreground="#DCDCAA" Margin="0,0,6,0" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="Foreground" Value="#D4D4D4"/>
                            <Setter Property="Padding" Value="4,2"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </DockPanel>
        </Border>

        <TabControl x:Name="MainTabControl" ItemsSource="{Binding OpenTabs}" SelectedItem="{Binding ActiveTab}">
            <TabControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </TabControl.ItemsPanel>

            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayTitle}" VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0"/>
                        <Button Content="×"
                                Style="{StaticResource TabCloseButtonStyle}"
                                Command="{Binding DataContext.CloseCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <avalon:TextEditor x:Name="Editor"
                             ShowLineNumbers="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="{StaticResource JetBrainsMono}"
                             FontSize="14"
                             Background="#1E1E1E"
                             Foreground="#D4D4D4"
                             BorderThickness="0"
                             
                             Loaded="Editor_Loaded"/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

    </DockPanel>
</core:AnimatedWindow>

